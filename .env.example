# Copy this file to .env and fill in real values. Never commit .env.
# .env holds secrets only -- all non-secret behavior lives in config/*.yaml.

# Which backend to run: mt5 | binance | mock
BROKER_BACKEND=mock

# Safety: keep true until you have explicitly verified demo/testnet setup.
DRY_RUN=true

# --- MT5 (Windows only) ---
# The variable NAMES below are the defaults from config/mt5.yaml (login_env, password_env,
# server_env) -- rename both sides together if you need to point at different variables.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Real orders are additionally gated by config/mt5.yaml's allow_live_trading flag (false
# by default) -- setting these credentials alone does not enable live order placement.

# --- Binance ---
# The variable NAMES below are the defaults from config/binance.yaml (api_key_env,
# api_secret_env) -- rename both sides together if you need to point at different variables.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Futures testnet by default; do not set to false without explicit review.
BINANCE_TESTNET=true
# Real orders are additionally gated by config/binance.yaml's allow_live_trading flag
# (false by default) -- setting these credentials alone does not enable live order placement.
